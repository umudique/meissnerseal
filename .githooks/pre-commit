#!/usr/bin/env bash
# Arcanum pre-commit hook
# Target: < 20 seconds
# Miri and full tests run in CI, not here.
#
# Install: git config core.hooksPath .githooks
# Or run:  scripts/setup-dev.sh

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}  ✓${NC} $1"; }
fail() { echo -e "${RED}  ✗${NC} $1"; exit 1; }
warn() { echo -e "${YELLOW}  !${NC} $1"; }

echo "arcanum pre-commit"
echo "──────────────────"

# ── Stage 1: Format ──────────────────────────────────────────────────────────
printf "[1/4] format  "
if cargo fmt --all -- --check 2>/dev/null; then
    pass "ok"
else
    fail "formatting errors — run: cargo fmt --all"
fi

# ── Stage 2: Compile ─────────────────────────────────────────────────────────
printf "[2/4] check   "
if cargo check --workspace --all-targets --quiet 2>/dev/null; then
    pass "ok"
else
    echo ""
    cargo check --workspace --all-targets 2>&1 | tail -20
    fail "compilation errors"
fi

# ── Stage 3: Lint ────────────────────────────────────────────────────────────
printf "[3/4] clippy  "
if cargo clippy --workspace --all-targets --all-features -- -D warnings \
     --quiet 2>/dev/null; then
    pass "ok"
else
    echo ""
    cargo clippy --workspace --all-targets --all-features -- -D warnings 2>&1 \
        | grep -E "^error|^warning" | head -20
    fail "clippy warnings/errors — all warnings are treated as errors"
fi

# ── Stage 4: CVE scan ────────────────────────────────────────────────────────
printf "[4/4] audit   "
if command -v cargo-audit &>/dev/null || cargo audit --version &>/dev/null 2>&1; then
    if cargo audit --quiet 2>/dev/null; then
        pass "ok"
    else
        echo ""
        cargo audit 2>&1 | tail -10
        fail "cargo audit found vulnerabilities — escalate to human before proceeding"
    fi
else
    warn "cargo-audit not installed — skipping (install: cargo install cargo-audit)"
fi

echo "──────────────────"
echo -e "${GREEN}pre-commit passed${NC}"
